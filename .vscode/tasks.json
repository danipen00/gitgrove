{
  // Convenience tasks (Cmd+Shift+B runs the default build). Not required for F5
  // — the debugger launches electron-vite directly — but handy for one-off runs.
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev",
      "detail": "Run the app with hot reload",
      "type": "shell",
      "command": "bun run dev",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "build",
      "detail": "Bundle main / preload / renderer into out/",
      "type": "shell",
      "command": "bun run build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "typecheck",
      "detail": "Type-check the whole project",
      "type": "shell",
      "command": "bun run typecheck",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "package (mac)",
      "detail": "Build and package a distributable",
      "type": "shell",
      "command": "bun run dist:mac",
      "problemMatcher": []
    }
  ]
}
